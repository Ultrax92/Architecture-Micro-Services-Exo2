<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
  </head>
  <body>
    <nav>
      <a href="/">Livres</a>
      <a href="/orders">Commandes</a>
      <a href="/payments">Paiements</a>
    </nav>

    <h1>Commandes</h1>

    <% if (msg) { %>
      <p class="flash">
        <% if (msg === 'created') { %>Commande creee avec succes.<% } %>
        <% if (msg === 'updated') { %>Commande modifiee avec succes.<% } %>
        <% if (msg === 'deleted') { %>Commande supprimee avec succes.<% } %>
      </p>
    <% } %>

    <% if (orders.length === 0) { %>
      <p>Aucune commande pour le moment.</p>
    <% } else { %>
      <table>
        <thead>
          <tr><th>Client</th><th>Date</th><th>Montant</th><th>Statut</th><th>Actions</th></tr>
        </thead>
        <tbody>
          <% orders.forEach(function (order) { %>
            <tr>
              <td><%= order.customerName %></td>
              <td><%= order.orderDate %></td>
              <td><%= order.totalAmount %></td>
              <td><%= order.status %></td>
              <td>
                <a href="/orders/<%= order.id %>/edit">Modifier</a>
                <form action="/orders/<%= order.id %>/delete" method="post" class="inline"
                      onsubmit="return confirm('Supprimer cette commande ?');">
                  <button type="submit" class="danger">Supprimer</button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>

    <h2>Creer une commande</h2>
    <form action="/orders/add" method="post">
      <input type="text" name="customerName" placeholder="Nom du client" required />
      <input type="date" name="orderDate" />
      <input type="number" step="0.01" name="totalAmount" placeholder="Montant total" />
      <input type="text" name="status" placeholder="Statut (ex: pending)" />
      <button type="submit">Creer</button>
    </form>
  </body>
</html>
