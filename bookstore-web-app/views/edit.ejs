<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
  </head>
  <body>
    <nav>
      <a href="/">Livres</a>
      <a href="/orders">Commandes</a>
      <a href="/payments">Paiements</a>
    </nav>

    <h1>Modifier le livre</h1>

    <form action="/edit/<%= book.id %>" method="post">
      <p><label>Titre :
        <input type="text" name="title" value="<%= book.title %>" required /></label></p>
      <p><label>Auteur :
        <input type="text" name="author" value="<%= book.author == null ? '' : book.author %>" /></label></p>
      <p><label>Prix :
        <input type="number" step="0.01" name="price" value="<%= book.price == null ? '' : book.price %>" /></label></p>
      <p><label>Stock :
        <input type="number" name="stock" value="<%= book.stock == null ? '' : book.stock %>" /></label></p>
      <button type="submit">Enregistrer</button>
      <a href="/">Annuler</a>
    </form>
  </body>
</html>
